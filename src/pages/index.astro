---
import { Image } from 'astro:assets';
import Layout from '../components/Layout.astro';
import Socials from '../components/Socials.astro';
import me from '../assets/me.jpeg';
---

<Layout
  title="Chandana Veeturi — Data, Finance and Product"
  description="Chandana Veeturi — building at the intersection of data, finance, and product."
>
  <div class="hero hero-with-photo">
    <div>
      <div class="hero-eyebrow">Data · Finance · Product</div>
      <h1 class="hero-name">Chandana Veeturi</h1>
      <p class="hero-tagline">
        Building at the <em>intersection</em> of data &amp; finance.
      </p>
      <p class="hero-desc">
        Business Analyst with hands-on experience in data analysis, financial
        modelling, and business intelligence — working across Excel, MySQL,
        Power BI, and Alteryx to turn messy financial data into products people
        actually use.
      </p>
      <p class="hero-desc">
        Skilled in project management, data visualization, and end-to-end
        client onboarding. Holds an MBA and a B.Tech, with certifications
        across project management and BI platforms.
      </p>
      <p class="hero-desc">
        Proven ability to deliver scalable, data-driven solutions across
        finance and tech domains. Currently leading a 0→1 credit product at a
        fintech in Hyderabad — previously at an investment bank in Mumbai and a
        consulting firm in Bengaluru.
      </p>

      <Socials />

      <div class="hero-tags">
        <span class="tag">Excel · MySQL</span>
        <span class="tag">Power BI · Alteryx</span>
        <span class="tag">Project Management</span>
        <span class="tag">Data Visualization</span>
        <span class="tag">BRD / FRD · Wireframing</span>
        <span class="tag">MBA · B.Tech</span>
      </div>
      <div class="hero-cta">
        <a class="btn-primary" href="/projects">See my work</a>
        <a class="btn-ghost" href="/blog">Read the blog</a>
        <a class="btn-ghost" href="/resume">View résumé</a>
      </div>
    </div>

    <a href="/about" class="hero-photo" aria-label="About Chandana">
      <Image src={me} alt="Chandana Veeturi" width={320} height={320} loading="eager" />
    </a>
  </div>
</Layout>
