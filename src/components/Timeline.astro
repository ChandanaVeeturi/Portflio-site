---
import { getCollection } from 'astro:content';

const entries = (await getCollection('timeline')).sort(
  (a, b) => b.data.year - a.data.year,
);

function rangeLabel(year: number, endYear?: number) {
  if (!endYear || endYear === year) return `${year}`;
  return `${year} – ${endYear}`;
}
---

<ol class="timeline">
  {
    entries.map((entry) => (
      <li class={`timeline-item type-${entry.data.type}`}>
        <div class="timeline-dot" aria-hidden="true" />
        <div class="timeline-meta">
          <span class="timeline-year">
            {rangeLabel(entry.data.year, entry.data.endYear)}
          </span>
          <span class="timeline-type">{entry.data.type}</span>
        </div>
        <div class="timeline-body">
          <h3 class="timeline-title">{entry.data.title}</h3>
          {entry.data.org && (
            <p class="timeline-org">
              {entry.data.org}
              {entry.data.location && (
                <span class="timeline-location"> · {entry.data.location}</span>
              )}
            </p>
          )}
          <p class="timeline-summary">{entry.data.summary}</p>
        </div>
      </li>
    ))
  }
</ol>

<style>
  .timeline {
    list-style: none;
    padding: 0;
    margin: 2rem 0;
    position: relative;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 7rem;
    top: 0.6rem;
    bottom: 0.6rem;
    width: 0.5px;
    background: var(--border);
  }

  .timeline-item {
    position: relative;
    display: grid;
    grid-template-columns: 7rem 1fr;
    gap: 1.5rem;
    padding: 0.6rem 0 1.6rem;
  }

  .timeline-dot {
    position: absolute;
    left: 7rem;
    top: 0.85rem;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--surface);
    border: 1.5px solid var(--muted);
    transform: translateX(-50%);
    transition: transform 0.25s, border-color 0.25s, background-color 0.25s;
  }

  .timeline-item.type-work .timeline-dot {
    border-color: var(--accent);
    background: var(--accent);
  }
  .timeline-item.type-education .timeline-dot {
    border-color: var(--accent);
    background: var(--surface);
  }
  .timeline-item.type-life .timeline-dot {
    background: var(--accent-dark);
    border-color: var(--accent-dark);
  }

  .timeline-item:hover .timeline-dot {
    transform: translateX(-50%) scale(1.4);
  }

  .timeline-meta {
    display: flex;
    flex-direction: column;
    gap: 2px;
    text-align: right;
    padding-right: 1.1rem;
    padding-top: 0.15rem;
  }

  .timeline-year {
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    color: var(--ink);
  }

  .timeline-type {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
  }

  .timeline-body {
    padding-left: 0.5rem;
  }

  .timeline-title {
    font-family: 'DM Serif Display', serif;
    font-size: 18px;
    font-weight: 400;
    margin: 0 0 0.2em;
    color: var(--ink);
  }

  .timeline-org {
    margin: 0 0 0.4em;
    color: var(--accent);
    font-size: 13px;
    font-weight: 500;
  }

  .timeline-location {
    color: var(--muted);
    font-weight: 400;
  }

  .timeline-summary {
    margin: 0;
    color: var(--muted);
    font-size: 13.5px;
    line-height: 1.65;
  }

  @media (max-width: 600px) {
    .timeline::before {
      left: 0.5rem;
    }
    .timeline-item {
      grid-template-columns: 1fr;
      gap: 0.3rem;
      padding-left: 1.5rem;
    }
    .timeline-dot {
      left: 0.5rem;
      top: 0.7rem;
    }
    .timeline-meta {
      flex-direction: row;
      gap: 0.6rem;
      text-align: left;
      padding-right: 0;
    }
    .timeline-body {
      padding-left: 0;
    }
  }
</style>
